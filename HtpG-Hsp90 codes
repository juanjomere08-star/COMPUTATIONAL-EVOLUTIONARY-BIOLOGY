

#LIMPIEZA DE SECUENCIAS#
import os

def limpiar_fasta(archivo_entrada, archivo_salida):
    if not os.path.exists(archivo_entrada):
        print(f"Error: No se encuentra {archivo_entrada}")
        return

    with open(archivo_entrada, 'r') as f_in, open(archivo_salida, 'w') as f_out:
        for linea in f_in:
            if linea.startswith(">"):
                f_out.write(linea)
            else:
                # Elimina 'X' y otros caracteres no aminoacídicos
                secuencia_limpia = "".join([c for c in linea if c.upper() in "ACDEFGHIKLMNPQRSTVWY\n"])
                f_out.write(secuencia_limpia)
    print(f"Archivo limpio guardado en: {archivo_salida}")

# Ejecución
limpiar_fasta("ancestro_n0.fasta", "ancestro_n0_limpio.fasta")

